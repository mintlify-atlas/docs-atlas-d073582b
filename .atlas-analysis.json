  "keyFeatures": [
    "Cross-chain token bridging across 16+ blockchains",
    "Cross-chain swaps with EXACT_IN and EXACT_OUT modes",
    "Unified balance aggregation across all supported chains",
    "Smart contract execution with automatic bridging",
    "Intent-based architecture with user approval hooks",
    "Transaction simulation and gas estimation",
    "Real-time progress events for building UIs",
    "Complete testnet coverage for development"
  ],
